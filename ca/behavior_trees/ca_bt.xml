<?xml version="1.0"?>
<root main_tree_to_execute="BehaviorTree">
    <!-- ////////// -->
    <BehaviorTree ID="BehaviorTree">
        <ReactiveFallback>
            <Sequence name="Sequence for reacting to the fleet status">
                <Condition ID="IsFleetMessageGet" name="Is there FleetMessage?  "/>
                <Condition ID="IsError" name="check if there is a error and if so, compose the command"/>
                <Action ID="SendCommand" name="Send the Command to respected robot"/>
               
            </Sequence>
            <Sequence name="Sequence to see if there is any robot are coming back to live">
                <Condition ID="IsCollectorResume" name="Is there a Collector resumed from error?  "/>
                <Action ID="SendCommand" name="if so, send the Command to respected robot"/>
          
            </Sequence>
            <AlwaysSuccess/>
        </ReactiveFallback>
    </BehaviorTree>
    <!-- ////////// -->
    <TreeNodesModel>
        <Condition ID="IsCollectorResume"/>
        <Condition ID="IsError"/>
        <Condition ID="IsFleetMessageGet"/>
        <Action ID="Print">
            <inout_port name="message"/>
        </Action>
        <Action ID="SendCommand"/>
    </TreeNodesModel>
    <!-- ////////// -->
</root>

